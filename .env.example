# Agent runtime: "anthropic" (default, uses ANTHROPIC_API_KEY) or "claude-code"
# (uses the `claude` CLI subprocess — runs on your Claude Code login,
#  no API key needed; custom tools are NOT exposed to the agent in this mode).
RUNTIME=anthropic

# LLM (only used when RUNTIME=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Claude Code binary path (only used when RUNTIME=claude-code)
CLAUDE_BINARY=claude

# Lark
LARK_APP_ID=
LARK_APP_SECRET=
# Optional: verification token from your Lark app's Event Subscriptions page.
# When set, /webhook/lark requires a valid X-Lark-Signature on every request.
LARK_VERIFICATION_TOKEN=
# Optional: Lark open_id of the default CSM. Approval cards go here when a
# customer profile has no csmLarkUserId set. Without this, drafts only appear
# in the admin UI queue, not in Lark.
DEFAULT_CSM_LARK_USER_ID=

# Server
PORT=3000
BRAIN_LOOP_INTERVAL_MS=300000
DB_PATH=~/.cerebro-claw/data.db

# Bash tool (comma-separated allowlist of commands the agent can run)
BASH_ALLOWLIST=curl,cat,head,tail,ls,grep,find,jq,date,echo,wc
BASH_TIMEOUT_MS=30000

# Extensions directory (server loads custom extensions from here at startup)
EXTENSIONS_DIR=./extensions

# CSP backend (Customer Success Platform — the real business data source).
# Used by the csp-connector extension. When set, the agent prefers CSP data
# over the local seed/memory store. Leave unset to run in demo mode.
CSP_BASE_URL=http://localhost:5656
CSP_TOKEN=
# Default CSM email used by csp_list_my_accounts when the agent doesn't
# supply one explicitly. Matches CSP's assignedCsmId / assignedCsmEmail.
CSP_CSM_EMAIL=

# Security: bearer token required on all /api/* endpoints when set.
# If unset, the admin API is open (suitable for local dev only).
ADMIN_TOKEN=

# Web
VITE_API_URL=http://localhost:3000
