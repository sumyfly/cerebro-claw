# Agent runtime: the `claude` CLI subprocess — runs on your Claude Code login,
# no Anthropic API key needed. Custom tools (csp_*, memory_*, send_message,
# etc.) are exposed to the subprocess via an HTTP MCP server it connects to.
#
# Claude Code binary path (must be on PATH or given as an absolute path).
CLAUDE_BINARY=claude

# Model the subprocess runs with. Defaults to claude-sonnet-4-20250514.
MODEL=claude-sonnet-4-20250514

# Lark
LARK_APP_ID=
LARK_APP_SECRET=
# Optional: verification token from your Lark app's Event Subscriptions page.
# When set, /webhook/lark requires a valid X-Lark-Signature on every request.
LARK_VERIFICATION_TOKEN=
# Optional: Lark open_id of the default CSM. Approval cards go here when a
# customer profile has no csmLarkUserId set. Without this, drafts only appear
# in the admin UI queue, not in Lark.
DEFAULT_CSM_LARK_USER_ID=

# Server
PORT=5100

# Deployment mode. Case-insensitive. Anything other than "Production" keeps the
# interval-driven brain loop OFF — dev/staging never burn tokens on their own.
# Manual cycles (POST /api/brain/cycle) still work in every mode.
MODE=Development

BRAIN_LOOP_INTERVAL_MS=300000
# Opt-OUT inside production: set false to suppress auto-start even when MODE=Production.
# Outside production this is ignored — MODE governs.
BRAIN_LOOP_ENABLED=true
# Run a cycle immediately on boot. Default false — keeps watch-mode restarts from
# spending tokens. Set true only if you want an instant cycle on every server start.
BRAIN_LOOP_RUN_ON_START=false

# Dev profile (recommended): leave MODE=Development and trigger a single cycle
# when you want to test. Real CSP data only — no stub fallback.
#   curl -X POST 'http://localhost:5100/api/brain/cycle?limit=1'
DB_PATH=~/.cerebro-claw/data.db

# Bash tool (comma-separated allowlist of commands the agent can run)
BASH_ALLOWLIST=curl,cat,head,tail,ls,grep,find,jq,date,echo,wc
BASH_TIMEOUT_MS=30000


# Action policy
# ─────────────
# How often the notify-then-act dispatcher polls for due customer sends.
# Default 60s. Lower for development, raise if you want to coalesce sends.
DISPATCHER_INTERVAL_MS=60000
# Default pause window (minutes) for notify_then_send_to_customer when the
# agent didn't pick one. 240 = 4h per work-inventory.md.
DEFAULT_PAUSE_MINUTES=240

# Verification (the critic): an adversarial check that a high-stakes action
# follows from its justification before it commits. The third gate, alongside
# the override floor and the pause window.
#   VERIFY_ENABLED=false  → disable (actions proceed as before).
#   VERIFY_BANDS          → which bands are gated (default notify-then-act,escalate).
#   VERIFIER_MODEL        → run the critic on its own cheaper/faster model
#                           (e.g. claude-haiku-4-5-20251001). Unset = share the main agent.
VERIFY_ENABLED=true
VERIFY_BANDS=notify-then-act,escalate
VERIFIER_MODEL=

# CSP backend (Customer Success Platform — the real business data source).
# REQUIRED. The server refuses to boot without CSP_TOKEN — no stub fallback.
CSP_BASE_URL=http://localhost:5656
CSP_TOKEN=
# Default CSM email used by csp_list_my_accounts when the agent doesn't
# supply one explicitly. Matches CSP's assignedCsmId / assignedCsmEmail.
# When this AND CSP_TOKEN are set, the brain loop iterates over this CSM's
# real CSP portfolio instead of the local seed store.
CSP_CSM_EMAIL=
# Cap on accounts pulled from CSP per brain loop cycle (default 25, max 100).
# Lower this for quick verification runs since each account triggers an agent
# turn that can take 30-90s.
CSP_MAX_ACCOUNTS=25

# Task backend (the CSM's actual unit of work — CTA-derived tasks).
# Drives the task-autopilot loop: the agent pulls open tasks and works each one
# through the four-band action policy, then writes the outcome back.
#   - TASK_SOURCE=csp → live CSP Task API (reuses CSP_BASE_URL/CSP_TOKEN above).
#   - unset           → task sweep skipped (logged at startup). No stub option.
TASK_SOURCE=
# CSP task scope: "all" (whole org) or "mine" (token owner only). Default all.
TASK_SCOPE=all
# Max tasks pulled per brain-loop cycle (each triggers an agent turn).
TASK_MAX=25

# Renewal sweep: the agent works upcoming/at-risk renewals as a first-class input.
#   - RENEWAL_SOURCE=csp → derive from accounts + per-account renewals (reuses CSP_*).
#   - unset              → renewal sweep skipped (logged at startup). No stub option.
RENEWAL_SOURCE=
# Only sweep renewals due within this many days (or flagged at-risk). Default 90 (T-90 onward).
RENEWAL_WINDOW_DAYS=90

# Triage: rank subjects by risk x value x urgency and spend agent turns only on
# the top ones — so the agent works "the accounts that matter" and the loop
# scales. TRIAGE_MAX = max subjects worked per input per cycle (0 = disabled,
# work all). TRIAGE_MIN_SCORE = floor below which a subject isn't worth a turn.
TRIAGE_MAX=0
TRIAGE_MIN_SCORE=0

# Skip gate (change detection): an account whose signal fingerprint is unchanged,
# with no open Situation and no renewal inside the horizon, skips its agent turn.
# Never indefinitely — past SKIP_GATE_MAX_AGE_DAYS it is re-reviewed regardless.
#   SKIP_GATE=off → disable (every listed account is eligible each cycle).
SKIP_GATE=on
SKIP_GATE_RENEWAL_HORIZON_DAYS=90
SKIP_GATE_MAX_AGE_DAYS=7

# Max concurrent agent turns within a sweep (accounts/tasks/renewals). 1 = serial.
BRAIN_CONCURRENCY=3

# Set to true ONLY for dev/test against a CSP server with a self-signed or
# expired TLS cert (e.g. cspapi.test.shub.us). Disables TLS verification
# process-wide — never enable against production. Default: false.
CSP_INSECURE_TLS=false

# Security: bearer token required on all /api/* endpoints when set.
# If unset, the admin API is open (suitable for local dev only).
ADMIN_TOKEN=

# Web
VITE_API_URL=http://localhost:5100
# Bearer token for the admin API; must equal server ADMIN_TOKEN when that is set.
VITE_ADMIN_TOKEN=
