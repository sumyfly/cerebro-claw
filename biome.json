{
	"$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"files": {
		"ignore": ["node_modules", "dist", ".turbo"]
	},
	"overrides": [
		{
			"include": ["**/*.test.ts", "**/__tests__/**"],
			"linter": {
				"rules": {
					"style": { "noNonNullAssertion": "off" },
					"suspicious": { "noExplicitAny": "off" },
					"performance": { "noDelete": "off" }
				}
			}
		}
	]
}
